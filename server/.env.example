# DeepSeek（聊天）
# 在 platform.deepseek.com 注册 → API keys → 创建一个
DEEPSEEK_API_KEY=sk-...
# 可选；默认 deepseek-chat
DEEPSEEK_MODEL=deepseek-chat
# 可选；默认官方 endpoint
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions

# ElevenLabs（TTS / 你的声音克隆）
# M4 起需要。先在 elevenlabs.io 传 1-3 分钟样本克隆 → 拿到 voice_id 填到下面。
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_multilingual_v2

# Socket.IO 房间密钥（M4 远程控制）
# A 端和 B 端都要带这个 secret 才能加入房间。两个人用，硬编码即可。
# !!! 部署前一定改掉默认值 !!!
ROOM_SECRET=change-me

# 可选；默认 3030
PORT=3030

# 人设：目前只有 self_oc（默认）。想加新人设直接编辑 server/src/prompts.js
PET_PERSONA=self_oc

# === M4b 预留（本次 M4a 不用）===
# WebRTC STUN：国内访问 stun.l.google.com 不稳定。M4b 起可填国内公共 STUN：
#   stun:stun.miwifi.com:3478
#   stun:stun.qq.com:3478
# 或在本 VPS 上自建 coturn 只开 STUN（3478/UDP）。
# STUN_URL=stun:stun.miwifi.com:3478
