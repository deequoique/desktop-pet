# Socket.IO 预配置房间密钥。多个双人房间用英文逗号分隔。
ROOM_SECRET=change-me
# ROOM_SECRETS=room-one-secret,room-two-secret
# ROOM_GRACE_MS=30000
# Registry and member-private audio storage. Use a persistent writable directory in production.
# PET_DATA_DIR=/var/lib/desktop-pet

# 语音供应商：elevenlabs（默认）或 cosyvoice。同一 server 每次启用一个托管供应商。
# TTS_PROVIDER=elevenlabs

# ElevenLabs 托管模式：API Key 只保存在 server。
# ELEVENLABS_API_KEY=
# 允许客户端选择的声音白名单（不要把未获授权的 voice 放入列表）。
# ELEVENLABS_VOICES_JSON=[{"id":"voice-id","label":"我的声音"}]
# 兼容旧配置：未设置 JSON 时转换为单个 Default voice。
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5

# CosyVoice 3.5 Plus 托管模式（华北 2 / 北京）。音色 ID 必须由同一模型创建。
# TTS_PROVIDER=cosyvoice
# DASHSCOPE_API_KEY=
# DASHSCOPE_WORKSPACE_ID=
# COSYVOICE_MODEL=cosyvoice-v3.5-plus
# COSYVOICE_VOICES_JSON=[{"id":"cosyvoice-v3.5-plus-your-voice-id","label":"我的中文声音"}]
# COSYVOICE_WS_URL=
# TTS_RATE_LIMIT=10
# TTS_JOB_TTL_MS=60000

# ElevenLabs BYOK 无需额外开关：用户可在控制面板输入自己的 API Key。
# CosyVoice 当前只支持 server 托管白名单。
# Electron 使用系统安全存储保存；独立浏览器仅保存到当前页面会话内存。

PORT=3030

# WebRTC 双栈直连与 TURN 音频兜底。URL 可用英文逗号分隔。
# RTC_STUN_URLS=stun:turn.example.com:3478
# RTC_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# RTC_TURN_SHARED_SECRET=
# RTC_TURN_REALM=turn.example.com
# RTC_TURN_CREDENTIAL_TTL_SEC=43200
# RTC_ICE_TRANSPORT_POLICY=all
