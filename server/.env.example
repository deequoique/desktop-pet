# Socket.IO 预配置房间密钥。多个双人房间用英文逗号分隔。
ROOM_SECRET=change-me
# ROOM_SECRETS=room-one-secret,room-two-secret
# ROOM_GRACE_MS=30000

# ElevenLabs 托管模式：API Key 只保存在 server。
# ELEVENLABS_API_KEY=
# 允许客户端选择的声音白名单（不要把未获授权的 voice 放入列表）。
# ELEVENLABS_VOICES_JSON=[{"id":"voice-id","label":"我的声音"}]
# 兼容旧配置：未设置 JSON 时转换为单个 Default voice。
# ELEVENLABS_VOICE_ID=
# ELEVENLABS_MODEL=eleven_flash_v2_5
# TTS_RATE_LIMIT=10
# TTS_JOB_TTL_MS=60000

# BYOK 无需额外开关：用户可在控制面板输入自己的 ElevenLabs API Key。
# Electron 使用系统安全存储保存；独立浏览器仅保存到当前页面会话内存。

PORT=3030
