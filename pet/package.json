{
  "name": "desktop-pet",
  "version": "1.2.0-beta.1",
  "private": true,
  "description": "AI desktop pet (VRM) with remote control",
  "main": "src/main/index.js",
  "scripts": {
    "dev": "concurrently -k -n vite,electron -c blue,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:local": "concurrently -k -n server,vite,electron -c yellow,blue,green \"npm:dev:server\" \"npm:dev:renderer\" \"npm:dev:electron:local\"",
    "dev:server": "cd ../server && npm run dev",
    "dev:renderer": "node ../scripts/run-vite.cjs",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "dev:electron:local": "wait-on tcp:5173 tcp:3030 && electron .",
    "build:renderer": "node ../scripts/run-vite.cjs build",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:win": "npm run build:renderer && electron-builder --win nsis",
    "start": "electron ."
  },
  "build": {
    "appId": "com.deequoique.desktop-pet",
    "productName": "Desktop Pet",
    "directories": {
      "output": "release"
    },
    "files": [
      "src/main/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "deequoique",
        "repo": "desktop-pet"
      }
    ]
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/three": "^0.164.0",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.3",
    "vite": "^5.0.10",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^2.0.7",
    "@pixiv/three-vrm-animation": "^2.1.3",
    "electron-updater": "^6.1.8",
    "socket.io-client": "^4.7.5",
    "three": "^0.164.0"
  }
}
